# ── Model API keys ────────────────────────────────────────────────────────────
# Never use VITE_ prefix — these keys must stay server-side only (injected by Vite proxy)

# Claude (required for default model)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GPT-4o (optional — only needed if you select GPT-4o in the UI)
OPENAI_API_KEY=sk-your-openai-key-here

# Mistral Small / Mistral Moderation (optional)
MISTRAL_API_KEY=your-mistral-key-here

# Gemini Flash via Google AI Studio (optional — free tier available at aistudio.google.com)
GOOGLE_AI_KEY=your-google-ai-key-here

# xAI Grok (optional — paid, credits required at console.x.ai)
XAI_API_KEY=xai_your-key-here

# Groq (optional — free tier at console.groq.com, covers Llama 3.1 70B, Mixtral 8x7B, Gemma 2 9B)
GROQ_API_KEY=gsk_your-groq-key-here

# Hive Visual Moderation + AI-Generated Content Detection — same V3 key
# Get it at: https://thehive.ai/explore?api_keys=1 (Playground API Keys → +)
HIVE_API_KEY=your-hive-v3-key-here

# Llama 3.2 Vision via RunPod serverless vLLM (optional)
# RUNPOD_ENDPOINT_URL should be your RunPod endpoint base URL, e.g.:
#   https://<endpoint-id>-00000000.proxy.runpod.net
RUNPOD_API_KEY=your-runpod-key-here
RUNPOD_ENDPOINT_URL=https://your-endpoint-id.proxy.runpod.net

# "teacher" for the full config panel, "student" for chat only
# Defaults to "teacher" if unset or invalid
VITE_MODE=teacher

# "whitelist" (default) or "blacklist"
VITE_MODERATION_MODE=whitelist

# Comma-separated list of allowed topics (whitelist mode)
VITE_WHITELIST=math,science,history,biology,chemistry,physics

# Comma-separated list of blocked topics (blacklist mode)
VITE_BLACKLIST=violence,adult content,drugs,weapons,hacking

# Optional extra instructions injected into both classifier and assistant prompts
VITE_CUSTOM_INSTRUCTIONS=Always require students to show their working. Never write full essays for them.

# Set to "true" to enable debug logging in browser console and terminal (proxy logs)
# Set to "false" or leave unset for production
VITE_DEBUG=false
